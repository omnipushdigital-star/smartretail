package com.omnipush.smartretail.activities

import android.content.Intent
import android.os.Bundle
import android.os.Handler
import android.os.Looper
import android.util.Log
import android.view.View
import androidx.appcompat.app.AppCompatActivity
import androidx.lifecycle.lifecycleScope
import com.omnipush.smartretail.databinding.ActivityPlayerBinding
import com.omnipush.smartretail.managers.DeviceInspector
import com.omnipush.smartretail.managers.KioskManager
import com.omnipush.smartretail.managers.NetworkManager
import com.omnipush.smartretail.managers.UpdateManager
import com.omnipush.smartretail.managers.WebViewManager
import com.omnipush.smartretail.services.PlayerService
import com.omnipush.smartretail.utils.AppConstants
import com.omnipush.smartretail.utils.PreferenceManager
import com.omnipush.smartretail.managers.CommandManager
import android.os.SystemClock
import android.view.MotionEvent
import kotlinx.coroutines.delay
import kotlinx.coroutines.launch

class PlayerActivity : AppCompatActivity() {

    companion object {
        private const val TAG = "PlayerActivity"
    }

    private lateinit var binding: ActivityPlayerBinding
    private lateinit var prefManager: PreferenceManager
    private lateinit var kioskManager: KioskManager
    private lateinit var webViewManager: WebViewManager
    private lateinit var deviceInspector: DeviceInspector
    private lateinit var commandManager: CommandManager // New
    private lateinit var networkManager: NetworkManager
    private lateinit var updateManager: UpdateManager
    private lateinit var androidHealth: com.omnipush.smartretail.managers.AndroidHealth

    private var heartbeatStarted = false
    
    // Admin gesture detection
    private var tapCount = 0
    private var lastTapTime = 0L
    private val adminHandler = Handler(Looper.getMainLooper())

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        
        Log.d(TAG, "Creating PlayerActivity")

        binding = ActivityPlayerBinding.inflate(layoutInflater)
        setContentView(binding.root)

        prefManager = PreferenceManager(this)
        kioskManager = KioskManager(this)
        webViewManager = WebViewManager(this)
        deviceInspector = DeviceInspector(this)
        commandManager = CommandManager(this) // Initialize
        networkManager = NetworkManager()
        updateManager = UpdateManager(this)

        // Initialize Android Health with the new PlayerView
        androidHealth = com.omnipush.smartretail.managers.AndroidHealth(
            this,
            deviceInspector,
            kioskManager,
            prefManager,
            binding.exoPlayerView
        )

        try {
            setupUI()
            setupWebView()
        } catch (e: Exception) {
            Log.e(TAG, "Critical initialization error: ${e.message}", e)
        }
        startPlayerService()
        
        if (!heartbeatStarted) {
            heartbeatStarted = true
            startHeartbeat()
        }
        
        setupAdminGesture()

        Log.d(TAG, "PlayerActivity created successfully")
    }

    private fun setupUI() {
        try {
            kioskManager.enableImmersiveMode(this)
            kioskManager.setMaxBrightness(this)
            
            binding.tvDeviceCode.text = prefManager.deviceCode

            if (prefManager.kioskEnabled) {
                kioskManager.enterKioskMode(this)
            }
        } catch (e: Exception) {
            Log.e(TAG, "setupUI failed: ${e.message}")
        }
    }

    private fun setupWebView() {
        webViewManager.configure(
            webView = binding.webView,
            androidHealth = androidHealth,
            onPageLoaded = {
                runOnUiThread {
                    binding.loadingLayout.visibility = View.GONE
                    binding.webView.visibility = View.VISIBLE
                }
            },
            onError = { errorMsg ->
                Log.e(TAG, "Player error: $errorMsg")
                runOnUiThread {
                    binding.tvOfflineStatus.text = errorMsg
                    binding.offlineLayout.visibility = View.VISIBLE
                    scheduleReload()
                }
            }
        )

        val url = prefManager.buildPlayerUrl()
        webViewManager.loadPlayer(binding.webView, url)
        
        // Safety Timeout to ensure player shows even if WebView hangs
        adminHandler.postDelayed({
            try {
                if (binding.loadingLayout.visibility == View.VISIBLE) {
                    Log.w(TAG, "Loading timeout: Forcing display visibility")
                    binding.loadingLayout.visibility = View.GONE
                    binding.webView.visibility = View.VISIBLE
                }
            } catch (e: Exception) { }
        }, 15000)

        // Force a click on the WebView after it loads to satisfy autoplay policies
        binding.webView.postDelayed({
            simulateUserClick()
        }, 2000)
    }

    private fun simulateUserClick() {
        binding.webView.post {
            val downTime = SystemClock.uptimeMillis()
            val eventTime = SystemClock.uptimeMillis() + 100
            val x = binding.webView.width / 2f
            val y = binding.webView.height / 2f

            val downEvent = MotionEvent.obtain(downTime, eventTime, MotionEvent.ACTION_DOWN, x, y, 0)
            val upEvent = MotionEvent.obtain(downTime, eventTime + 50, MotionEvent.ACTION_UP, x, y, 0)

            try {
                binding.webView.dispatchTouchEvent(downEvent)
                binding.webView.dispatchTouchEvent(upEvent)
                Log.d(TAG, "Simulated interaction sent to unlock media engine")
            } finally {
                downEvent.recycle()
                upEvent.recycle()
            }
        }
    }
    // ... rest of the file truncated for brevity ...
